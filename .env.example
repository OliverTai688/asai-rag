# --- Database (Prisma & Supabase) ---
# Runtime connection for Prisma Client.
# For serverless / autoscaling deployments, use Supabase transaction pooler.
DATABASE_URL="postgres://prisma.[PROJECT-REF]:[PRISMA-PASSWORD]@[DB-REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma CLI / migrations connection.
# Prefer direct connection when IPv6 is available; otherwise use Supavisor session mode on port 5432.
DIRECT_URL="postgres://prisma.[PROJECT-REF]:[PRISMA-PASSWORD]@[DB-REGION].pooler.supabase.com:5432/postgres"
# DIRECT_URL="postgresql://prisma:[PRISMA-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# --- Supabase Client (Frontend) ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# --- AI & LLM Services ---
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."

# --- Voice Services (Optional) ---
ELEVENLABS_API_KEY="your-key"
DEEPGRAM_API_KEY="your-key"

# --- App Config ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"

# --- Level 3 Auth Providers ---
# Account/password is stored in DB with server-side scrypt hashes.
# Google OAuth is enabled only when both values are present.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email verification-code login and real invite email delivery use Resend HTTP API.
RESEND_API_KEY=""
EMAIL_FROM="誠問 AI <no-reply@example.com>"

# For Level 3 production, keep true so org invites fail closed if email cannot be sent.
ENABLE_REAL_INVITE_EMAIL="true"

# --- Demo / Development Fixtures ---
# Mock API routes return 404 in production unless this explicit escape hatch is enabled.
# Keep false for production-like environments.
ALLOW_MOCK_API="false"

# Local-only auth escape hatch for route/API development before Supabase Auth env is wired.
# Never enable in production. When true, server auth helpers accept x-asai-demo-user-email.
ALLOW_DEV_AUTH_HEADER="false"

# Show the one-click demo login (seeded isDemo accounts + fixed passwords) on the login page.
# Safe to enable on the public beta deployment (Vercel) — it does NOT enable the dangerous
# x-asai-demo-user-email header bypass. Requires demo accounts to be seeded (pnpm demo:seed:reset).
ENABLE_DEMO_LOGIN="false"

# Legacy Theater is allowed only for staging/demo proof until Route B is complete.
# Keep false in production so /api/ai/theater returns THEATER_ROUTE_B_REQUIRED instead of serving legacy flow.
ENABLE_LEGACY_THEATER_DEMO="false"
